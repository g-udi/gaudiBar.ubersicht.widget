#!/usr/bin/env bash

CORES=$(sysctl -n hw.ncpu 2>/dev/null || printf '1')
CPU=$(ps -A -o %cpu | awk -v cores="$CORES" '{s+=$1} END {if (cores > 0) printf "%.1f", s / cores; else printf "%.1f", s}')
HDD=$(df -g / | awk 'NR == 2 {print $4}')
MEMORY=$(ps -A -o %mem | awk '{s+=$1} END {printf "%.1f", s}')
NETWORK=$(bash "${GAUDI_BAR_WIDGET_DIR:-gaudiBar.ubersicht.widget}/lib/plugins/stats/network-traffic")

printf '{"cpu":"%s","hdd":"%s","memory":"%s","network":"%s"}\n' "$CPU" "$HDD" "$MEMORY" "$NETWORK"
