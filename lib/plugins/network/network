#!/usr/bin/env bash

json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

CURRENT_SERVICE=""
CURRENT_DEVICE=""
SERVICES=$(networksetup -listnetworkserviceorder 2>/dev/null | grep 'Hardware Port' || true)

while IFS= read -r line; do
    service_name=$(printf '%s\n' "$line" | awk -F '(, )|(: )|[)]' '{print $2}')
    service_device=$(printf '%s\n' "$line" | awk -F '(, )|(: )|[)]' '{print $4}')

    if [[ -n "$service_device" ]] && ifconfig "$service_device" 2>/dev/null | grep -q 'status: active'; then
        CURRENT_SERVICE="$service_name"
        CURRENT_DEVICE="$service_device"
        break
    fi
done <<< "$SERVICES"

WIFI_STATUS=""
WIFI_SSID=""
IP_ADDRESS=""

if [[ -n "$CURRENT_DEVICE" ]]; then
    WIFI_STATUS=$(ifconfig "$CURRENT_DEVICE" 2>/dev/null | awk -F': ' '/status:/ {print $2; exit}')
    IP_ADDRESS=$(ifconfig "$CURRENT_DEVICE" 2>/dev/null | awk '/inet / && $2 != "127.0.0.1" {print $2; exit}')
fi

if [[ "$CURRENT_SERVICE" == "Wi-Fi" || "$CURRENT_SERVICE" == "AirPort" ]]; then
    wifi_output=$(networksetup -getairportnetwork "$CURRENT_DEVICE" 2>/dev/null || true)
    case "$wifi_output" in
        "Current Wi-Fi Network: "*)
            WIFI_SSID=${wifi_output#Current Wi-Fi Network: }
            ;;
    esac
fi

printf '{"service":"%s","status":"%s","ssid":"%s","ip":"%s"}\n' \
    "$(json_escape "$CURRENT_SERVICE")" \
    "$(json_escape "$WIFI_STATUS")" \
    "$(json_escape "$WIFI_SSID")" \
    "$(json_escape "$IP_ADDRESS")"
