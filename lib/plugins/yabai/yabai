#!/usr/bin/env bash

json_error() {
  printf '{"activeWindow":null,"layout":null,"error":"%s"}\n' "$1"
}

if command -v yabai >/dev/null 2>&1; then
  yabai_path=$(command -v yabai)
elif [[ -x /opt/homebrew/bin/yabai ]]; then
  yabai_path="/opt/homebrew/bin/yabai"
elif [[ -x /usr/local/bin/yabai ]]; then
  yabai_path="/usr/local/bin/yabai"
else
  json_error "yabai_not_installed"
  exit 0
fi

if ! pgrep -x yabai >/dev/null 2>&1; then
  json_error "yabai_not_running"
  exit 0
fi

layout=$("$yabai_path" -m query --spaces --space 2>/dev/null)
if [ -z "$layout" ]; then
  layout="null"
fi

current_window=$("$yabai_path" -m query --windows --window 2>/dev/null)
if [ -z "$current_window" ]; then
  current_window="null"
fi

printf '{"activeWindow":%s,"layout":%s}\n' "$current_window" "$layout"
